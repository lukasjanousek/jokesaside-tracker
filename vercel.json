{
  "rewrites": [
    {
      "source": "/tracker",
      "destination": "/tracker/index.html"
    },
    {
      "source": "/tasks",
      "destination": "/tasks/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "task.jokesaside.cz"
        }
      ],
      "destination": "/tasks",
      "permanent": true
    }
  ]
}